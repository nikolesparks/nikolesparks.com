---
import Layout from '../layouts/Layout.astro';
import { site, offices } from '../data/site';
---

<Layout
  title={`Contact — Free 15-Minute Consultation | ${site.name}`}
  description="Reach out for a free 15-minute consultation. Depth-oriented therapy in Newport Beach, Fullerton, or online throughout California."
  active="/contact/"
  path="/contact/"
>
  <!-- Hero: headline left, consultation form right -->
  <section class="hero form-row">
    <div class="col gap-28">
      <p class="eyebrow">Contact</p>
      <h1>Let’s talk about what you’re carrying and what you want next.</h1>
      <p>
        I offer a free 15-minute consultation to help you decide whether this feels like the
        right fit. If you’re looking for depth-oriented therapy in Orange County or online in
        California, I’d be glad to hear from you.
      </p>
      <a class="cta" href={`mailto:${site.email}`}>Email me directly <span class="arw">→</span></a>
    </div>

    <div class="form-card blue">
      <p class="eyebrow on-color">Schedule a free consultation</p>
      <h2>Start the conversation</h2>
      <!--
        Netlify Forms: `data-netlify` + hidden `form-name` let Netlify detect and
        process submissions at deploy time. The honeypot `bot-field` traps spam.
        Submissions are emailed to the practice and stored in the Netlify dashboard.
      -->
      <form
        name="contact"
        method="POST"
        data-netlify="true"
        netlify-honeypot="bot-field"
        action="/contact/success/"
        class="form"
      >
        <input type="hidden" name="form-name" value="contact" />
        <p class="hp" aria-hidden="true">
          <label>Don’t fill this out if you’re human: <input name="bot-field" /></label>
        </p>
        <label class="field">
          Name
          <input type="text" name="name" autocomplete="name" placeholder="Your name" required />
        </label>
        <div class="field-row">
          <label class="field">
            Email
            <input type="email" name="email" autocomplete="email" placeholder="you@example.com" required />
          </label>
          <label class="field">
            Phone
            <input type="tel" name="phone" autocomplete="tel" placeholder="(000) 000-0000" required />
          </label>
        </div>
        <div class="field-row">
          <label class="field">
            Preferred location
            <select name="preferred-location" required>
              <option value="" disabled selected>Select a location…</option>
              <option value="Online">Online</option>
              <option value="Newport Beach">Newport Beach</option>
              <option value="Fullerton">Fullerton</option>
            </select>
          </label>
          <label class="field">
            Preferred service
            <select name="preferred-service" required>
              <option value="" disabled selected>Select a service…</option>
              <option value="Individual Therapy">Individual Therapy</option>
              <option value="Couples Therapy">Couples Therapy</option>
              <option value="Teen Therapy">Teen Therapy</option>
              <option value="Premarital Counseling">Premarital Counseling</option>
            </select>
          </label>
        </div>
        <label class="field">
          What would you like to talk about?
          <textarea
            name="message"
            placeholder="Please share a little bit about what you're looking for and your schedule availability for a phone call."
            required></textarea>
        </label>
        <button type="submit">Send message</button>
        <p class="note">
          This form is not a secure or confidential channel — please don’t share sensitive
          clinical details. For emergencies, call 988 or 911.
        </p>
      </form>
    </div>
  </section>

  <!-- Lower: what to expect + direct contact info (cream) -->
  <section class="panel-grid">
    <div class="panel">
      <p class="eyebrow">Quick note</p>
      <h2>What to expect from your first outreach</h2>
      <p class="body">
        You can reach out with any questions about therapy, fit, availability, or what it
        might be like to work together. I’ll reply as soon as I can and help you take the next
        step at your pace.
      </p>
      <div class="list">
        <div>• A brief reply within a few business days</div>
        <div>• A free 15-minute consultation if it feels like a fit</div>
        <div>• Clear information about scheduling and logistics</div>
      </div>
    </div>

    <div class="panel">
      <p class="eyebrow">Other ways to reach me</p>
      <h2>Prefer to connect directly?</h2>
      <div class="detail">
        <div class="label">Email</div>
        <a class="value" href={`mailto:${site.email}`}>{site.email}</a>
      </div>
      <div class="detail">
        <div class="label">Phone</div>
        <a class="value" href={site.phoneHref}>{site.phone}</a>
      </div>
      <div class="detail">
        <div class="label">Locations</div>
        <div class="plain">
          {offices.map((o) => o.name).join(' · ')} · Online throughout California
        </div>
      </div>
    </div>
  </section>
</Layout>

---
import Layout from '../layouts/Layout.astro';
import { site, offices } from '../data/site';
import { content } from '../data/content';

const c = content.contact;
const f = c.form;
---

<Layout title={c.metaTitle} description={c.metaDescription} active="/contact/" path="/contact/">
  <!-- Hero: headline left, consultation form right -->
  <section class="hero form-row">
    <div class="col gap-28">
      <p class="eyebrow">{c.hero.eyebrow}</p>
      <h1>{c.hero.heading}</h1>
      <p>{c.hero.lead}</p>
      <a class="cta" href={`mailto:${site.email}`}>Email me directly <span class="arw">→</span></a>
    </div>

    <div class="form-card blue">
      <p class="eyebrow on-color">{f.eyebrow}</p>
      <h2>{f.heading}</h2>
      <!--
        Netlify Forms: `data-netlify` + hidden `form-name` let Netlify detect and
        process submissions at deploy time. The honeypot `bot-field` traps spam.
        Submissions are emailed to the practice and stored in the Netlify dashboard.
      -->
      <form
        name="contact"
        method="POST"
        data-netlify="true"
        netlify-honeypot="bot-field"
        action="/contact/success/"
        class="form"
      >
        <input type="hidden" name="form-name" value="contact" />
        <p class="hp" aria-hidden="true">
          <label>Don’t fill this out if you’re human: <input name="bot-field" /></label>
        </p>
        <label class="field">
          Name
          <input type="text" name="name" autocomplete="name" placeholder="Your name" required />
        </label>
        <div class="field-row">
          <label class="field">
            Email
            <input type="email" name="email" autocomplete="email" placeholder="you@example.com" required />
          </label>
          <label class="field">
            Phone
            <input type="tel" name="phone" autocomplete="tel" placeholder="(000) 000-0000" required />
          </label>
        </div>
        <div class="field-row">
          <label class="field">
            {f.locationLabel}
            <select name="preferred-location" required>
              <option value="" disabled selected>Select a location…</option>
              {f.locations.map((o) => <option value={o}>{o}</option>)}
            </select>
          </label>
          <label class="field">
            {f.serviceLabel}
            <select name="preferred-service" required>
              <option value="" disabled selected>Select a service…</option>
              {f.services.map((o) => <option value={o}>{o}</option>)}
            </select>
          </label>
        </div>
        <label class="field">
          {f.messageLabel}
          <textarea name="message" placeholder={f.messagePlaceholder} required></textarea>
        </label>
        <button type="submit">Send message</button>
        <p class="note">{f.note}</p>
      </form>
    </div>
  </section>

  <!-- Lower: what to expect + direct contact info (cream) -->
  <section class="panel-grid">
    <div class="panel">
      <p class="eyebrow">{c.expect.eyebrow}</p>
      <h2>{c.expect.heading}</h2>
      <p class="body">{c.expect.body}</p>
      <div class="list">
        {c.expect.list.map((item) => <div>• {item}</div>)}
      </div>
    </div>

    <div class="panel">
      <p class="eyebrow">{c.direct.eyebrow}</p>
      <h2>{c.direct.heading}</h2>
      <div class="detail">
        <div class="label">Email</div>
        <a class="value" href={`mailto:${site.email}`}>{site.email}</a>
      </div>
      <div class="detail">
        <div class="label">Phone</div>
        <a class="value" href={site.phoneHref}>{site.phone}</a>
      </div>
      <div class="detail">
        <div class="label">Locations</div>
        <div class="plain">
          {offices.map((o) => o.name).join(' · ')} · Online throughout California
        </div>
      </div>
    </div>
  </section>
</Layout>

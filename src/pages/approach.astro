---
import Layout from '../layouts/Layout.astro';
import Ticker from '../components/Ticker.astro';
import Portrait from '../components/Portrait.astro';
import Glyph from '../components/Glyph.astro';
import Illustration from '../components/Illustration.astro';
import NextSteps from '../components/NextSteps.astro';
import { content } from '../data/content';

const c = content.approach;
---

<Layout
  title={c.metaTitle}
  description={c.metaDescription}
  active="/approach/"
  path="/approach/"
>
  <!-- Hero -->
  <section class="hero">
    <div class="col">
      <p class="eyebrow">{c.hero.eyebrow}</p>
      <h1 set:html={c.hero.heading}></h1>
      <p>{c.hero.lead}</p>
      <a class="cta" href="/contact/">Schedule a free consultation <span class="arw">→</span></a>
    </div>
    <Illustration name="depth" size="clamp(240px, 34vw, 380px)" class="hero-illustration" />
  </section>

  <Ticker items={c.ticker} label="Modalities" />

  <!-- Philosophy -->
  <section class="section split c-narrow-wide">
    <div class="col gap-20">
      <p class="eyebrow">{c.philosophy.eyebrow}</p>
      <h2 class="h2-serif" set:html={c.philosophy.heading}></h2>
      <Glyph name="target-ellipses" class="mt-16" />
    </div>
    <div class="prose prose-15" style="gap:24px;">
      {c.philosophy.paras.map((p) => <p>{p}</p>)}
    </div>
  </section>

  <!-- Quote -->
  <section class="quote-block">
    <Glyph name="rings" class="hero-figure" />
    <div class="col gap-28">
      <blockquote set:html={c.quote.text}></blockquote>
      <cite>{c.quote.cite}</cite>
    </div>
  </section>

  <!-- Areas of focus -->
  <section class="section sage on-color">
    <div class="section-heading">
      <div class="stack">
        <p class="eyebrow on-color">{c.areas.eyebrow}</p>
        <h2 class="serif" style="font-size:48px; line-height:1.1">{c.areas.heading}</h2>
      </div>
      <p>{c.areas.intro}</p>
    </div>
    <div class="split c-1-1" style="align-items:start; gap:72px; margin-bottom:56px">
      <div class="pill-block">
        <div class="label">Who I work with</div>
        <div class="pill-row">{c.areas.whoIWorkWith.map((p) => <span class="pill">{p}</span>)}</div>
      </div>
      <div class="pill-block">
        <div class="label">What I treat</div>
        <div class="pill-row">{c.areas.whatITreat.map((p) => <span class="pill">{p}</span>)}</div>
      </div>
    </div>
    <div class="card-row">
      <a class="service-card primary" href="/services/individual-therapy/"><span>Individual therapy</span><span class="arw" aria-hidden="true">→</span></a>
      <a class="service-card secondary" href="/services/couples-therapy/"><span>Couples therapy</span><span class="arw" aria-hidden="true">→</span></a>
    </div>
  </section>

  <!-- What to expect -->
  <section class="section split c-media">
    <Portrait placeholder="Office or session photo" accent="bl" />
    <div class="col">
      <p class="eyebrow">{c.whatToExpect.eyebrow}</p>
      <h2 class="h2-serif" set:html={c.whatToExpect.heading}></h2>
      {c.whatToExpect.paras.map((p) => <p class="body">{p}</p>)}
      <a class="text-link" href="/about/">{c.whatToExpect.link} <span class="arw">→</span></a>
    </div>
  </section>

  <NextSteps heading={c.next.heading} copy={c.next.copy} />
</Layout>

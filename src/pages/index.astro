---
import Layout from '../layouts/Layout.astro';
import Ticker from '../components/Ticker.astro';
import Portrait from '../components/Portrait.astro';
import Glyph from '../components/Glyph.astro';
import Illustration from '../components/Illustration.astro';
import { site } from '../data/site';
import { content } from '../data/content';

const c = content.home;

// SVG glyphs stay in the page; labels come from content.
const glyphSvgs = [
  `<circle cx="60" cy="60" r="50" stroke="#707748" stroke-width="1"/><circle cx="60" cy="60" r="34" stroke="#707748" stroke-width="1"/><circle cx="60" cy="60" r="18" stroke="#707748" stroke-width="1"/><circle cx="60" cy="60" r="4" fill="#3B63C4"/>`,
  `<circle cx="60" cy="60" r="48" stroke="#707748" stroke-width="1"/><line x1="60" y1="12" x2="60" y2="108" stroke="#707748" stroke-width="1"/><line x1="12" y1="60" x2="108" y2="60" stroke="#707748" stroke-width="1"/><line x1="26" y1="26" x2="94" y2="94" stroke="#707748" stroke-width="1"/><line x1="94" y1="26" x2="26" y2="94" stroke="#707748" stroke-width="1"/><circle cx="60" cy="60" r="4" fill="#C7D64F"/>`,
  `<circle cx="44" cy="60" r="34" stroke="#707748" stroke-width="1"/><circle cx="76" cy="60" r="34" stroke="#707748" stroke-width="1"/><circle cx="60" cy="60" r="4" fill="#3B63C4"/>`,
  `<ellipse cx="60" cy="72" rx="50" ry="12" stroke="#707748" stroke-width="1"/><ellipse cx="60" cy="62" rx="50" ry="22" stroke="#707748" stroke-width="1"/><ellipse cx="60" cy="52" rx="50" ry="32" stroke="#707748" stroke-width="1"/><circle cx="60" cy="20" r="4" fill="#C7D64F"/>`,
];
const soundIllus = ['anxiety', 'relationships', 'success', 'disconnection'] as const;
---

<Layout active="/" path="/">
  <!-- Hero -->
  <section class="hero">
    <div class="col">
      <p class="eyebrow">{c.hero.eyebrow}</p>
      <h1 set:html={c.hero.heading}></h1>
      <p>{c.hero.lead}</p>
      <a class="cta" href="/contact/">Schedule a free consultation <span class="arw">→</span></a>
    </div>
    <Glyph name="orbit" class="hero-figure" />
  </section>

  <Ticker items={c.ticker} label="Areas of focus" />

  <!-- What the work moves toward -->
  <section class="section tight" aria-labelledby="glyph-heading">
    <p class="eyebrow" id="glyph-heading" style="text-align:center; margin-bottom:32px">
      {c.movesTowardEyebrow}
    </p>
    <div class="grid-4">
      {
        c.glyphLabels.map((label, i) => (
          <div class="glyph-card">
            <svg viewBox="0 0 120 120" width="96" height="96" fill="none" aria-hidden="true" set:html={glyphSvgs[i]} />
            <span class="label">{label}</span>
          </div>
        ))
      }
    </div>
  </section>

  <!-- Sound familiar -->
  <section class="section tight" aria-labelledby="sound-familiar">
    <div class="section-heading">
      <div class="stack">
        <p class="eyebrow">{c.soundFamiliar.eyebrow}</p>
        <h2 id="sound-familiar" class="serif" style="font-size:48px; line-height:1.1; max-width:640px">
          {c.soundFamiliar.heading}
        </h2>
      </div>
      <p>{c.soundFamiliar.aside}</p>
    </div>
    <div class="ruled-grid cols-2 feature">
      {
        c.soundFamiliar.cards.map((copy, i) => (
          <article class="ruled-cell">
            <div class="meta">
              <span class="num">{String(i + 1).padStart(2, '0')}</span>
              <Illustration name={soundIllus[i]} size="52px" />
            </div>
            <div class="copy">{copy}</div>
          </article>
        ))
      }
    </div>
  </section>

  <!-- Approach -->
  <section class="section blue on-color split c-narrow-wide" aria-labelledby="approach-title" style="align-items:center">
    <div class="col gap-28">
      <p class="eyebrow on-color">{c.approach.eyebrow}</p>
      <h2 id="approach-title" class="h2-serif" style="font-size:52px" set:html={c.approach.heading}></h2>
      <p class="body">{c.approach.body}</p>
      <a class="text-link on-color" href="/approach/">{c.approach.link} <span class="arw">→</span></a>
    </div>
    <Glyph name="nested-ellipses" class="hero-figure" />
  </section>

  <!-- About preview -->
  <section class="section split c-media" aria-labelledby="about-title">
    <Portrait placeholder="Nikole — candid photo" accent="bl" />
    <div class="col">
      <p class="eyebrow">{c.aboutPreview.eyebrow}</p>
      <h2 id="about-title" class="serif" style="font-size:52px; line-height:1.1" set:html={c.aboutPreview.heading}></h2>
      <p class="label" style="color:var(--ink-65)">{site.supervisor.replace('Supervised by', 'AMFT 150080 · Supervised by')}</p>
      {c.aboutPreview.paras.map((p) => <p class="body">{p}</p>)}
      <a class="text-link" href="/about/">{c.aboutPreview.link} <span class="arw">→</span></a>
    </div>
  </section>

  <!-- Services -->
  <section class="section sage on-color relative overflow-clip" aria-labelledby="services-title">
    <Glyph name="radiate" class="decor" />
    <div class="section-heading">
      <div class="stack">
        <p class="eyebrow on-color">{c.services.eyebrow}</p>
        <h2 id="services-title" class="serif" style="font-size:48px; line-height:1.1">{c.services.heading}</h2>
      </div>
      <p>{c.services.intro}</p>
    </div>

    <div class="split c-1-1" style="align-items:start; gap:72px; margin-bottom:36px">
      <div class="pill-block">
        <div class="label">Who I see</div>
        <div class="pill-row">{c.services.whoISee.map((p) => <span class="pill">{p}</span>)}</div>
      </div>
      <div class="pill-block">
        <div class="label">What we work on</div>
        <div class="pill-row">{c.services.whatWeWork.map((p) => <span class="pill">{p}</span>)}</div>
      </div>
    </div>

    <div class="card-row">
      <a class="service-card primary" href="/services/individual-therapy/"><span>Individual therapy</span><span class="arw" aria-hidden="true">→</span></a>
      <a class="service-card secondary" href="/services/couples-therapy/"><span>Couples therapy</span><span class="arw" aria-hidden="true">→</span></a>
    </div>
  </section>
</Layout>

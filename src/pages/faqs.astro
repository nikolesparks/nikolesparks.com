---
import Layout from '../layouts/Layout.astro';
import Ticker from '../components/Ticker.astro';
import Glyph from '../components/Glyph.astro';
import Faq from '../components/Faq.astro';
import NextSteps from '../components/NextSteps.astro';
import { content } from '../data/content';

const c = content.faqs;
---

<Layout title={c.metaTitle} description={c.metaDescription} active="/faqs/" path="/faqs/">
  <!-- Hero -->
  <section class="hero">
    <div class="col">
      <p class="eyebrow">{c.hero.eyebrow}</p>
      <h1 set:html={c.hero.heading}></h1>
      <p set:html={c.hero.lead}></p>
      <a class="cta" href="/contact/">Schedule a free consultation <span class="arw">→</span></a>
    </div>
    <Glyph name="concentric" class="hero-figure" />
  </section>

  <Ticker items={c.ticker} label="Topics" />

  <!-- FAQ list -->
  <section class="section" style="display:grid; grid-template-columns:1fr 1.6fr; gap:80px; align-items:start">
    <div class="sticky-heading">
      <p class="eyebrow">{c.listEyebrow}</p>
      <h2 class="serif" style="font-size:44px; line-height:1.12; text-wrap:pretty">{c.listHeading}</h2>
      <Glyph name="target-ellipses" class="mt-16" />
    </div>
    <Faq items={c.faqs} openFirst />
  </section>

  <NextSteps heading={c.next.heading} copy={c.next.copy} />
</Layout>

<style>
  @media (max-width: 820px) {
    section[style*='grid-template-columns:1fr 1.6fr'] {
      grid-template-columns: 1fr !important;
      gap: 40px !important;
    }
  }
</style>

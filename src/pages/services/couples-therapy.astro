---
import Layout from '../../layouts/Layout.astro';
import Illustration from '../../components/Illustration.astro';
import NextSteps from '../../components/NextSteps.astro';
import { couplesTherapyService } from '../../data/schema';

const whoIWorkWith = [
  'Couples experiencing communication breakdowns who feel like they’re speaking different languages',
  'Partners navigating significant life transitions, career changes, becoming parents, empty nesting',
  'Relationships where one or both partners feel unheard, unseen, or misunderstood',
  'Couples considering whether to stay together or separate who need clarity and guidance',
  'Couples wanting preventative maintenance to strengthen an already good relationship',
  'Partners wanting to deepen intimacy and emotional connection',
  'High-functioning couples experiencing persistent conflicts over the same issues',
  'Couples preparing for marriage, seeking <a href="/services/premarital-counseling/" style="color:var(--blue); border-bottom:1px solid var(--blue)">premarital counseling</a> to explore attachment histories and expectations',
];

const process = [
  { title: 'Creating safety', copy: 'Our initial sessions establish a space where both partners feel safe to express themselves honestly. We identify the patterns in your relationship and what’s happening beneath the surface of your conflicts.', icon: `<circle cx="24" cy="24" r="18" stroke="#C7D64F" stroke-width="1"/><circle cx="24" cy="24" r="4" fill="#C7D64F"/>` },
  { title: 'Developing understanding', copy: 'You’ll gain insight into how your individual histories and attachment styles influence your relationship. This understanding often brings compassion where there was previously frustration.', icon: `<circle cx="24" cy="24" r="18" stroke="#C7D64F" stroke-width="1"/><circle cx="24" cy="24" r="11" stroke="#C7D64F" stroke-width="1"/><circle cx="24" cy="24" r="4" fill="#C7D64F"/>` },
  { title: 'Learning to Show Up for Each Other', copy: 'As things progress, you’ll both get better at noticing what the other actually needs, and responding to it. That builds a foundation where you can both feel seen, which makes more vulnerability and closeness possible.', icon: `<circle cx="18" cy="24" r="13" stroke="#C7D64F" stroke-width="1"/><circle cx="30" cy="24" r="13" stroke="#C7D64F" stroke-width="1"/>` },
  { title: 'Deepening connection', copy: 'As we address the patterns that create distance, many couples find their bond strengthened, and a relationship spacious enough to hold the needs of two separate people choosing to journey together.', icon: `<circle cx="18" cy="24" r="13" stroke="#C7D64F" stroke-width="1"/><circle cx="30" cy="24" r="13" stroke="#C7D64F" stroke-width="1"/><circle cx="24" cy="24" r="4" fill="#C7D64F"/>` },
];
---

<Layout
  title="Couples Therapy in Newport Beach & Fullerton | Nikole Sparks, AMFT"
  description="Attachment-based couples therapy in Newport Beach & Fullerton, CA (telehealth statewide). Work through conflict, disconnection & communication patterns."
  active="/services/"
  path="/services/couples-therapy/"
  schema={[couplesTherapyService]}
>
  <!-- Hero (sage) -->
  <section class="hero sage on-color">
    <div class="col">
      <p class="eyebrow on-color"><a href="/services/">Services</a> / Couples therapy</p>
      <h1>Reconnect, rebuild, and rediscover <em>your relationship.</em></h1>
      <p>
        Attachment-based couples therapy in Newport Beach, Fullerton &amp; online throughout
        California. I work with the relationship itself — not taking sides.
      </p>
      <a class="cta on-blue" href="/contact/">Schedule a free consultation <span class="arw">→</span></a>
    </div>
    <Illustration name="connection-full" size="clamp(380px, 44vw, 520px)" color="var(--cream)" class="hero-figure" />
  </section>

  <!-- Approach (cream) -->
  <section class="section split c-wide-narrow">
    <div class="col gap-28">
      <p class="eyebrow">The approach</p>
      <h2 class="h2-serif" style="font-size:52px">We work together <em>on the relationship.</em></h2>
      <p class="body">My approach draws on attachment principles, helping you understand how your individual histories influence your current relationship patterns. Rather than taking sides, I work with the couple as a unit. Together, we’ll explore the unconscious patterns creating disconnection, develop more satisfying ways to connect, and build a stronger foundation for intimacy and understanding.</p>
      <p class="body">Looking for support on your own? Explore <a href="/services/individual-therapy/" style="color:var(--blue); border-bottom:1px solid var(--blue)">individual therapy</a>, or read more <a href="/about/" style="color:var(--blue); border-bottom:1px solid var(--blue)">about Nikole</a>.</p>
      <a class="text-link" href="/approach/">My approach <span class="arw">→</span></a>
    </div>
    <svg class="hero-figure" viewBox="0 0 380 320" fill="none" aria-hidden="true">
      <circle cx="150" cy="160" r="110" stroke="#3B63C4" stroke-width="1"></circle>
      <circle cx="230" cy="160" r="110" stroke="#3B63C4" stroke-width="1"></circle>
      <circle cx="190" cy="160" r="6" fill="#C7D64F"></circle>
    </svg>
  </section>

  <!-- Who I work with -->
  <section class="section">
    <div class="stack gap-20" style="margin-bottom:48px">
      <p class="eyebrow">Who I work with</p>
      <h2 class="serif" style="font-size:48px; line-height:1.1; max-width:720px; text-wrap:pretty">
        Couples at every stage, from preparing for marriage to reconnecting with each other.
      </h2>
    </div>
    <div class="ruled-grid cols-2">
      {whoIWorkWith.map((item, i) => (
        <div class="ruled-cell">
          <span class="num">{String(i + 1).padStart(2, '0')}</span>
          <span class="copy" set:html={item} />
        </div>
      ))}
    </div>
  </section>

  <!-- Process -->
  <section class="section sage on-color">
    <div class="stack gap-20" style="margin-bottom:48px">
      <p class="eyebrow on-color">The process</p>
      <h2 class="serif" style="font-size:48px; line-height:1.1">How the work unfolds</h2>
    </div>
    <div class="process-grid cols-2">
      {process.map((p, i) => (
        <div class="process-card">
          <div class="head">
            <span class="num">{String(i + 1).padStart(2, '0')}</span>
            <svg viewBox="0 0 48 48" width="34" height="34" fill="none" aria-hidden="true" set:html={p.icon} />
          </div>
          <div class="title">{p.title}</div>
          <p>{p.copy}</p>
        </div>
      ))}
    </div>
  </section>

  <NextSteps
    heading="Ready to begin? <em>Let’s talk.</em>"
    copy="I offer a free phone consultation — a chance to ask questions and get a feel for how we might work together. In-person in Newport Beach and Fullerton, or via telehealth throughout California."
  />
</Layout>

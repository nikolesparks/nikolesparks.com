---
import Layout from '../../layouts/Layout.astro';
import Glyph from '../../components/Glyph.astro';
import Faq from '../../components/Faq.astro';
import NextSteps from '../../components/NextSteps.astro';
import { content } from '../../data/content';

const c = content.premarital;
---

<Layout title={c.metaTitle} description={c.metaDescription} active="/services/" path="/services/premarital-counseling/">
  <!-- Hero (sage) -->
  <section class="hero sage on-color">
    <div class="col">
      <p class="eyebrow on-color"><a href="/services/">Services</a> / {c.hero.crumb}</p>
      <h1 set:html={c.hero.heading}></h1>
      <p set:html={c.hero.lead}></p>
      <a class="cta on-blue" href="/contact/">Schedule a free consultation <span class="arw">→</span></a>
    </div>
    <svg class="hero-figure" viewBox="0 0 480 460" fill="none" aria-hidden="true">
      <circle cx="190" cy="230" r="130" stroke="#F6F1E4" stroke-width="1"></circle>
      <circle cx="290" cy="230" r="130" stroke="#F6F1E4" stroke-width="1"></circle>
      <circle cx="240" cy="230" r="180" stroke="#F6F1E4" stroke-width="1"></circle>
      <circle cx="240" cy="50" r="7" fill="#C7D64F"></circle>
      <circle cx="240" cy="230" r="6" fill="#F6F1E4"></circle>
    </svg>
  </section>

  <!-- What is premarital (cream) -->
  <section class="section split c-narrow-wide" style="align-items:center; grid-template-columns:1fr 380px">
    <div class="col gap-28">
      <p class="eyebrow">{c.what.eyebrow}</p>
      <h2 class="h2-serif" style="font-size:52px" set:html={c.what.heading}></h2>
      <p class="body" set:html={c.what.body}></p>
      <a class="text-link" href="/approach/">My approach <span class="arw">→</span></a>
    </div>
    <svg class="hero-figure" viewBox="0 0 380 320" fill="none" aria-hidden="true">
      <circle cx="150" cy="160" r="110" stroke="#3B63C4" stroke-width="1"></circle>
      <circle cx="230" cy="160" r="110" stroke="#3B63C4" stroke-width="1"></circle>
      <circle cx="190" cy="160" r="6" fill="#C7D64F"></circle>
    </svg>
  </section>

  <!-- Who this is for -->
  <section class="section">
    <div class="stack gap-20" style="margin-bottom:48px">
      <p class="eyebrow">{c.whoEyebrow}</p>
      <h2 class="serif" style="font-size:48px; line-height:1.1; max-width:720px; text-wrap:pretty">{c.whoHeading}</h2>
    </div>
    <div class="ruled-grid cols-2">
      {c.who.map((item, i) => (
        <div class="ruled-cell">
          <span class="num">{String(i + 1).padStart(2, '0')}</span>
          <span class="copy">{item}</span>
        </div>
      ))}
    </div>
  </section>

  <!-- Process -->
  <section class="section sage on-color">
    <div class="stack gap-20" style="margin-bottom:48px">
      <p class="eyebrow on-color">{c.processEyebrow}</p>
      <h2 class="serif" style="font-size:48px; line-height:1.1">{c.processHeading}</h2>
    </div>
    <div class="process-grid cols-2">
      {c.process.map((p, i) => (
        <div class="process-card">
          <span class="num">{String(i + 1).padStart(2, '0')}</span>
          <div class="title">{p.title}</div>
          <p>{p.copy}</p>
        </div>
      ))}
    </div>
  </section>

  <!-- Packages & pricing -->
  <section class="section">
    <div class="section-heading">
      <div class="stack">
        <p class="eyebrow" set:html={c.packages.eyebrow}></p>
        <h2 class="serif" style="font-size:48px; line-height:1.1; max-width:640px; text-wrap:pretty" set:html={c.packages.heading}></h2>
      </div>
      <p set:html={c.packages.intro}></p>
    </div>
    <div class="card-row">
      {c.packages.list.map((pkg) => (
        <div class={`package ${pkg.variant}`}>
          <div class="label">{pkg.label}</div>
          <div class="title">{pkg.title}</div>
          <p class="desc">{pkg.desc}</p>
          <div class="includes">
            {pkg.includes.map((inc) => <div set:html={inc} />)}
          </div>
          <div class="price-wrap">
            <div class="price">{pkg.price}</div>
            <div class="price-note">{pkg.priceNote}</div>
          </div>
        </div>
      ))}
    </div>
    <p class="body" style="max-width:820px; margin-top:32px; font-size:15px; color:var(--ink-75)" set:html={c.packages.footnote}></p>
  </section>

  <!-- FAQs -->
  <section class="section" style="padding-top:0; display:grid; grid-template-columns:1fr 1.5fr; gap:80px; align-items:start">
    <div class="sticky-heading">
      <p class="eyebrow">{c.faqEyebrow}</p>
      <h2 class="h2-serif">Frequently asked questions</h2>
      <Glyph name="target-ellipses" class="mt-16" />
    </div>
    <Faq items={c.faqs} />
  </section>

  <NextSteps heading={c.next.heading} copy={c.next.copy} steps={c.next.steps} />
</Layout>

<style>
  @media (max-width: 820px) {
    section[style*='grid-template-columns:1fr 1.5fr'] {
      grid-template-columns: 1fr !important;
      gap: 40px !important;
    }
  }
</style>

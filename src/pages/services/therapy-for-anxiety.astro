---
import Layout from '../../layouts/Layout.astro';
import Ticker from '../../components/Ticker.astro';
import Glyph from '../../components/Glyph.astro';
import Faq from '../../components/Faq.astro';
import NextSteps from '../../components/NextSteps.astro';
import { content } from '../../data/content';

const c = content.anxiety;
const processIcons = [
  `<circle cx="24" cy="24" r="18" stroke="#C7D64F" stroke-width="1"/><circle cx="24" cy="24" r="4" fill="#C7D64F"/>`,
  `<circle cx="24" cy="24" r="18" stroke="#C7D64F" stroke-width="1"/><circle cx="24" cy="24" r="11" stroke="#C7D64F" stroke-width="1"/><circle cx="24" cy="24" r="4" fill="#C7D64F"/>`,
  `<ellipse cx="24" cy="28" rx="19" ry="6" stroke="#C7D64F" stroke-width="1"/><ellipse cx="24" cy="23" rx="19" ry="12" stroke="#C7D64F" stroke-width="1"/><circle cx="24" cy="9" r="3" fill="#C7D64F"/>`,
];
---

<Layout title={c.metaTitle} description={c.metaDescription} active="/services/" path="/services/therapy-for-anxiety/">
  <!-- Hero -->
  <section class="hero">
    <div class="col">
      <p class="eyebrow"><a href="/services/">Services</a> / {c.hero.crumb}</p>
      <h1 set:html={c.hero.heading}></h1>
      <p set:html={c.hero.lead}></p>
      <a class="cta" href="/contact/">Schedule a free consultation <span class="arw">→</span></a>
    </div>
    <svg class="hero-figure" viewBox="0 0 480 460" fill="none" aria-hidden="true">
      <circle cx="240" cy="230" r="190" stroke="#3B63C4" stroke-width="1"></circle>
      <circle cx="240" cy="230" r="150" stroke="#3B63C4" stroke-width="1"></circle>
      <circle cx="240" cy="230" r="110" stroke="#3B63C4" stroke-width="1"></circle>
      <circle cx="240" cy="230" r="70" stroke="#707748" stroke-width="1"></circle>
      <circle cx="240" cy="230" r="30" stroke="#707748" stroke-width="1"></circle>
      <circle cx="240" cy="230" r="6" fill="#C7D64F"></circle>
      <circle cx="240" cy="40" r="7" fill="#3B63C4"></circle>
    </svg>
  </section>

  <Ticker items={c.ticker} label="How anxiety shows up" />

  <!-- What anxiety can look like -->
  <section class="section">
    <div class="section-heading">
      <div class="stack">
        <p class="eyebrow">{c.looks.eyebrow}</p>
        <h2 class="serif" style="font-size:48px; line-height:1.1; max-width:640px; text-wrap:pretty">{c.looks.heading}</h2>
      </div>
      <p>{c.looks.aside}</p>
    </div>
    <div class="ruled-grid cols-2">
      {c.looks.items.map((item, i) => (
        <div class="ruled-cell">
          <span class="num">{String(i + 1).padStart(2, '0')}</span>
          <span class="copy">{item}</span>
        </div>
      ))}
    </div>
    <p class="body" style="max-width:720px; margin-top:32px">{c.looks.footnote}</p>
  </section>

  <!-- How I work with anxiety -->
  <section class="section blue on-color split c-narrow-wide" style="align-items:center; grid-template-columns:1fr 380px">
    <div class="col gap-28">
      <p class="eyebrow on-color">{c.how.eyebrow}</p>
      <h2 class="h2-serif" style="font-size:52px" set:html={c.how.heading}></h2>
      {c.how.paras.map((p) => <p class="body">{p}</p>)}
      <a class="text-link on-color" href="/approach/">My approach <span class="arw">→</span></a>
    </div>
    <Glyph name="nested-ellipses" class="hero-figure" />
  </section>

  <!-- Who I work with -->
  <section class="section">
    <div class="stack gap-20" style="margin-bottom:48px">
      <p class="eyebrow">{c.whoEyebrow}</p>
      <h2 class="serif" style="font-size:48px; line-height:1.1; max-width:720px; text-wrap:pretty">{c.whoHeading}</h2>
    </div>
    <div class="ruled-grid cols-2">
      {c.who.map((item, i) => (
        <div class="ruled-cell">
          <span class="num">{String(i + 1).padStart(2, '0')}</span>
          <span class="copy">{item}</span>
        </div>
      ))}
    </div>
  </section>

  <!-- What to expect -->
  <section class="section sage on-color">
    <div class="stack gap-20" style="margin-bottom:48px">
      <p class="eyebrow on-color">{c.expectEyebrow}</p>
      <h2 class="serif" style="font-size:48px; line-height:1.1">{c.expectHeading}</h2>
    </div>
    <div class="process-grid cols-3">
      {c.process.map((p, i) => (
        <div class="process-card">
          <div class="head">
            <span class="num">{String(i + 1).padStart(2, '0')}</span>
            <svg viewBox="0 0 48 48" width="34" height="34" fill="none" aria-hidden="true" set:html={processIcons[i]} />
          </div>
          <div class="title">{p.title}</div>
          <p>{p.copy}</p>
        </div>
      ))}
    </div>
  </section>

  <!-- FAQs -->
  <section class="section" style="display:grid; grid-template-columns:1fr 1.5fr; gap:80px; align-items:start">
    <div class="sticky-heading">
      <p class="eyebrow">{c.faqEyebrow}</p>
      <h2 class="h2-serif">Frequently asked questions</h2>
      <Glyph name="target-ellipses" class="mt-16" />
    </div>
    <Faq items={c.faqs} />
  </section>

  <NextSteps heading={c.next.heading} copy={c.next.copy} />
</Layout>

<style>
  @media (max-width: 820px) {
    section[style*='grid-template-columns:1fr 1.5fr'] {
      grid-template-columns: 1fr !important;
      gap: 40px !important;
    }
  }
</style>

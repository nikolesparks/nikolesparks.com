---
import Layout from '../../layouts/Layout.astro';
import Ticker from '../../components/Ticker.astro';
import Portrait from '../../components/Portrait.astro';
import Glyph from '../../components/Glyph.astro';
import Illustration from '../../components/Illustration.astro';
import Faq from '../../components/Faq.astro';
import NextSteps from '../../components/NextSteps.astro';
import { creativesTherapyService, faqPage } from '../../data/schema';

const tickerItems = ['Burnout', 'Imposter Syndrome', 'Perfectionism', 'Creative Blocks', 'Performance Anxiety', 'Self-Doubt'];

const whoIWorkWith = [
  { copy: 'Creatives facing inspiration dry spells, burnout, or uncertainty about their professional direction', icon: `<line x1="8" y1="40" x2="40" y2="8" stroke="#3B63C4" stroke-width="1"/><line x1="8" y1="30" x2="30" y2="8" stroke="#3B63C4" stroke-width="1"/><line x1="18" y1="40" x2="40" y2="18" stroke="#3B63C4" stroke-width="1"/><circle cx="40" cy="8" r="3" fill="#3B63C4"/>` },
  { copy: 'Outwardly successful people exhausted by the constant fear of being “found out” as not good enough', icon: `<circle cx="24" cy="24" r="20" stroke="#3B63C4" stroke-width="1"/><circle cx="24" cy="24" r="12" stroke="#3B63C4" stroke-width="1"/><circle cx="24" cy="24" r="3" fill="#3B63C4"/>` },
  { copy: 'High-functioning humans managing daily responsibilities while battling persistent emptiness or heaviness', icon: `<ellipse cx="24" cy="24" rx="19" ry="8" stroke="#3B63C4" stroke-width="1" transform="rotate(-24 24 24)"/><ellipse cx="24" cy="24" rx="19" ry="8" stroke="#3B63C4" stroke-width="1" transform="rotate(24 24 24)"/>` },
];

const togetherWeWill = [
  'Get to know the roots of your creative struggles',
  'Reconnect with what drew you to creative work',
  'Work through the murky stuff that sucks your energy',
  'Develop insight and freedom that applies to your creative life and beyond',
];

const steps = [
  { title: 'Initial consultation', copy: 'Reach out for a free consultation — share what brings you in and see if I’m the right fit for your needs.' },
  { title: 'Scheduling', copy: 'We’ll find a consistent time that works with your schedule — evening appointments are available for those with work commitments.' },
  { title: 'Begin sessions', copy: 'Choose telehealth or in-person visits in Newport Beach or Fullerton. We’ll design a plan that supports your goals and fosters progress.' },
];

const faqs = [
  {
    q: 'Do you specialize in therapy for creative professionals?',
    a: ['Yes. I spent over a decade working as a designer before becoming a therapist, so I am not approaching creative struggles from the outside looking in. I understand what it feels like to have your livelihood, identity, and sense of worth all tied up in your work. Issues like imposter syndrome, burnout, perfectionism, and the fear of being found out are real, and they deserve more than generic advice. This is a space where that complexity gets taken seriously.'],
  },
  {
    q: "What's the difference between burnout and depression? How do I know which one I'm dealing with?",
    a: ["Burnout and depression share a lot of surface features: exhaustion, disconnection, loss of motivation. But they have different roots, and the distinction matters for how we work together. Burnout typically emerges from a sustained mismatch between you and your environment, whether that's your workload, your values, recognition, or sense of control. Depression tends to run deeper and more pervasively into your sense of self. Often, the two coexist. Rather than chasing a label, our work focuses on understanding what's actually happening for you, which usually gets us further anyway."],
  },
  {
    q: "I'm still functioning well and I'm not in crisis. Is therapy still for me?",
    a: ["Absolutely. A lot of the people I work with are high-functioning by every external measure. They're showing up, delivering, meeting expectations, and running on empty at the same time. Therapy is not reserved for crisis. It's for anyone who wants to understand why they feel the way they feel, and who's ready to do something about it before it compounds."],
  },
  {
    q: 'Do you work with clients remotely, or do I need to come in person?',
    a: ['Both options are available. I see clients in person in Newport Beach and Fullerton, and via telehealth throughout California. A lot of creatives prefer telehealth for the flexibility, especially with irregular hours or a project-based schedule. We can figure out what works best for you during the consultation.'],
  },
  {
    q: 'How long does therapy typically take?',
    a: ["There's no honest single answer to this, and I'd be skeptical of anyone who gives you one. Psychodynamic work is intentionally open-ended. It's not built around a fixed number of sessions or a protocol to complete. That said, most people start noticing real shifts within a few months of consistent work. Some stay longer because they find value in the ongoing depth of it. We revisit this together as we go."],
  },
];
---

<Layout
  title="Creative Burnout & Imposter Syndrome Therapy | Newport Beach"
  description="Depth therapy for burnout, imposter syndrome & creative blocks in Newport Beach, CA — from a therapist who spent 15+ years as a designer."
  active="/services/"
  path="/services/therapy-for-creatives/"
  schema={[
    creativesTherapyService,
    faqPage(faqs, {
      id: 'https://nikolesparks.com/services/therapy-for-creatives#faq',
      url: 'https://nikolesparks.com/services/therapy-for-creatives',
    }),
  ]}
>
  <!-- Hero -->
  <section class="hero">
    <div class="col">
      <p class="eyebrow"><a href="/services/">Services</a> / Therapy for creatives</p>
      <h1>Navigate self-doubt &amp; burnout, to find <em>your voice again.</em></h1>
      <p>
        If you’ve ever struggled with burnout, imposter syndrome, performance anxiety, or
        creative blocks, you’re not alone. As a designer-turned-therapist, I help you
        understand the emotional undercurrents behind these challenges — so you can live a more
        full, dynamic, creative life.
      </p>
      <a class="cta" href="/contact/">Schedule a free consultation <span class="arw">→</span></a>
    </div>
    <Illustration name="creativity-full" size="clamp(280px, 34vw, 420px)" color="var(--blue)" class="hero-figure" />
  </section>

  <Ticker items={tickerItems} label="What we work on" />

  <!-- For the creative seeking balance -->
  <section class="section blue on-color split c-narrow-wide" style="align-items:center; grid-template-columns:1fr 380px">
    <div class="col gap-28">
      <p class="eyebrow on-color">For the creative seeking balance</p>
      <h2 class="h2-serif" style="font-size:52px">That space between inspiration and self-doubt? It’s where your most important <em>work begins.</em></h2>
      <p class="body">When your relationship with your work feels complicated, inconsistent, or confusing, it’s not a sign to push harder — it’s a sign to look deeper. If you’re tired of navigating the rollercoaster alone, there’s a different path forward.</p>
    </div>
    <Glyph name="nested-ellipses" class="hero-figure" />
  </section>

  <!-- Designer-turned-therapist -->
  <section class="section split c-media">
    <Portrait placeholder="Nikole — candid photo" accent="bl" />
    <div class="col">
      <p class="eyebrow">Designer-turned-therapist</p>
      <h2 class="serif" style="font-size:52px; line-height:1.1">I’ve lived in the spaces <em class="accent">you inhabit.</em></h2>
      <p class="body">Having spent over a decade immersed in the design world before becoming a therapist, I understand creative work and creative careers from the inside. When we work together, you’re partnering with someone who speaks both languages fluently: deep, meaningful psychological work — and the practical demands of creative life and expression.</p>
      <p class="body">I offer a space designed specifically for those whose work is deeply tied to their identities, intuition, personal point of view, and emotional lives.</p>
      <a class="text-link" href="/about/">About Nikole <span class="arw">→</span></a>
    </div>
  </section>

  <!-- Who I work with -->
  <section class="section" style="padding-top:0">
    <p class="eyebrow" style="margin-bottom:40px">Who I work with</p>
    <div class="ruled-grid cols-3 feature">
      {whoIWorkWith.map((item, i) => (
        <div class="ruled-cell">
          <div class="meta">
            <span class="num">{String(i + 1).padStart(2, '0')}</span>
            <svg viewBox="0 0 48 48" width="36" height="36" fill="none" aria-hidden="true" set:html={item.icon} />
          </div>
          <span class="copy">{item.copy}</span>
        </div>
      ))}
    </div>
  </section>

  <!-- Approach -->
  <section class="section sage on-color split c-1-1">
    <div class="col gap-28">
      <p class="eyebrow on-color">My approach — psychodynamic therapy</p>
      <h2 class="serif" style="font-size:48px; line-height:1.1; text-wrap:pretty">Taking a depth approach to therapy.</h2>
      <p class="body">Instead of advice, homework, or “just try this,” psychodynamic therapy offers something deeper — a chance to understand what’s actually going on beneath the surface of your creative, emotional life. The things that happened earlier in life, especially the ones we’re not fully aware of, influence how we think, feel, and act now. The goal is to notice those patterns, understand how they’re playing out, and free you up to live in a creative, generative way that reflects your truest self.</p>
      <p class="body">This work often overlaps with <a href="/services/individual-therapy/" style="color:var(--cream); border-bottom:1px solid var(--cream-35)">individual therapy</a>. Browse all <a href="/services/" style="color:var(--cream); border-bottom:1px solid var(--cream-35)">services</a>.</p>
      <a class="text-link on-color" href="/approach/">My approach <span class="arw">→</span></a>
    </div>
    <div class="steps">
      <div class="label" style="color:var(--lime); padding-bottom:18px">Together we will</div>
      {togetherWeWill.map((item, i) => (
        <div class="step">
          <span class="num">{String(i + 1).padStart(2, '0')}</span>
          <span class="txt">{item}</span>
        </div>
      ))}
    </div>
  </section>

  <!-- How to get started -->
  <section class="section">
    <div class="stack gap-20" style="margin-bottom:48px">
      <p class="eyebrow">How to get started</p>
      <h2 class="serif" style="font-size:48px; line-height:1.1">Three simple steps</h2>
    </div>
    <div class="process-grid cols-3">
      {steps.map((p, i) => (
        <div class="process-card" style="border-top-color:var(--ink-30)">
          <span class="num" style="color:var(--blue)">{String(i + 1).padStart(2, '0')}</span>
          <div class="title">{p.title}</div>
          <p style="color:var(--ink-85)">{p.copy}</p>
        </div>
      ))}
    </div>
  </section>

  <!-- FAQs -->
  <section class="section" style="display:grid; grid-template-columns:1fr 1.5fr; gap:80px; align-items:start">
    <div class="sticky-heading">
      <p class="eyebrow">Therapy for creatives</p>
      <h2 class="h2-serif">Frequently asked questions</h2>
      <Illustration name="questions-full" size="240px" class="mt-16" />
    </div>
    <Faq items={faqs} />
  </section>

  <NextSteps
    heading="Ready to begin? <em>Let’s talk.</em>"
    copy="If what you’ve read sounds interesting, I invite you to reach out. I offer a free 15-minute consultation — in-person in Newport Beach or Fullerton, or telehealth throughout California."
  />
</Layout>

<style>
  @media (max-width: 820px) {
    section[style*='grid-template-columns:1fr 1.5fr'] {
      grid-template-columns: 1fr !important;
      gap: 40px !important;
    }
  }
</style>

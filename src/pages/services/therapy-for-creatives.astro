---
import Layout from '../../layouts/Layout.astro';
import Ticker from '../../components/Ticker.astro';
import Portrait from '../../components/Portrait.astro';
import Glyph from '../../components/Glyph.astro';
import NextSteps from '../../components/NextSteps.astro';
import { content } from '../../data/content';

const c = content.creatives;
const whoIcons = [
  `<line x1="8" y1="40" x2="40" y2="8" stroke="#3B63C4" stroke-width="1"/><line x1="8" y1="30" x2="30" y2="8" stroke="#3B63C4" stroke-width="1"/><line x1="18" y1="40" x2="40" y2="18" stroke="#3B63C4" stroke-width="1"/><circle cx="40" cy="8" r="3" fill="#3B63C4"/>`,
  `<circle cx="24" cy="24" r="20" stroke="#3B63C4" stroke-width="1"/><circle cx="24" cy="24" r="12" stroke="#3B63C4" stroke-width="1"/><circle cx="24" cy="24" r="3" fill="#3B63C4"/>`,
  `<ellipse cx="24" cy="24" rx="19" ry="8" stroke="#3B63C4" stroke-width="1" transform="rotate(-24 24 24)"/><ellipse cx="24" cy="24" rx="19" ry="8" stroke="#3B63C4" stroke-width="1" transform="rotate(24 24 24)"/>`,
];
---

<Layout title={c.metaTitle} description={c.metaDescription} active="/services/" path="/services/therapy-for-creatives/">
  <!-- Hero -->
  <section class="hero">
    <div class="col">
      <p class="eyebrow"><a href="/services/">Services</a> / {c.hero.crumb}</p>
      <h1 set:html={c.hero.heading}></h1>
      <p set:html={c.hero.lead}></p>
      <a class="cta" href="/contact/">Schedule a free consultation <span class="arw">→</span></a>
    </div>
    <svg class="hero-figure" viewBox="0 0 480 460" fill="none" aria-hidden="true">
      <ellipse cx="240" cy="230" rx="190" ry="70" stroke="#3B63C4" stroke-width="1" transform="rotate(-30 240 230)"></ellipse>
      <ellipse cx="240" cy="230" rx="190" ry="70" stroke="#3B63C4" stroke-width="1" transform="rotate(30 240 230)"></ellipse>
      <ellipse cx="240" cy="230" rx="190" ry="70" stroke="#707748" stroke-width="1" transform="rotate(90 240 230)"></ellipse>
      <circle cx="240" cy="230" r="6" fill="#3B63C4"></circle>
      <circle cx="240" cy="40" r="7" fill="#C7D64F"></circle>
    </svg>
  </section>

  <Ticker items={c.ticker} label="What we work on" />

  <!-- For the creative seeking balance -->
  <section class="section blue on-color split c-narrow-wide" style="align-items:center; grid-template-columns:1fr 380px">
    <div class="col gap-28">
      <p class="eyebrow on-color">{c.balance.eyebrow}</p>
      <h2 class="h2-serif" style="font-size:52px" set:html={c.balance.heading}></h2>
      <p class="body">{c.balance.body}</p>
    </div>
    <Glyph name="nested-ellipses" class="hero-figure" />
  </section>

  <!-- Designer-turned-therapist -->
  <section class="section split c-media">
    <Portrait placeholder="Nikole — candid photo" accent="bl" />
    <div class="col">
      <p class="eyebrow">{c.designer.eyebrow}</p>
      <h2 class="serif" style="font-size:52px; line-height:1.1" set:html={c.designer.heading}></h2>
      {c.designer.paras.map((p) => <p class="body">{p}</p>)}
      <a class="text-link" href="/about/">{c.designer.link} <span class="arw">→</span></a>
    </div>
  </section>

  <!-- Who I work with -->
  <section class="section" style="padding-top:0">
    <p class="eyebrow" style="margin-bottom:40px">{c.whoEyebrow}</p>
    <div class="ruled-grid cols-3 feature">
      {c.who.map((copy, i) => (
        <div class="ruled-cell">
          <div class="meta">
            <span class="num">{String(i + 1).padStart(2, '0')}</span>
            <svg viewBox="0 0 48 48" width="36" height="36" fill="none" aria-hidden="true" set:html={whoIcons[i]} />
          </div>
          <span class="copy">{copy}</span>
        </div>
      ))}
    </div>
  </section>

  <!-- Approach -->
  <section class="section sage on-color split c-1-1">
    <div class="col gap-28">
      <p class="eyebrow on-color">{c.approach.eyebrow}</p>
      <h2 class="serif" style="font-size:48px; line-height:1.1; text-wrap:pretty">{c.approach.heading}</h2>
      <p class="body">{c.approach.body}</p>
      <a class="text-link on-color" href="/approach/">{c.approach.link} <span class="arw">→</span></a>
    </div>
    <div class="steps">
      <div class="label" style="color:var(--lime); padding-bottom:18px">{c.approach.listLabel}</div>
      {c.approach.list.map((item, i) => (
        <div class="step">
          <span class="num">{String(i + 1).padStart(2, '0')}</span>
          <span class="txt">{item}</span>
        </div>
      ))}
    </div>
  </section>

  <!-- How to get started -->
  <section class="section">
    <div class="stack gap-20" style="margin-bottom:48px">
      <p class="eyebrow">{c.stepsEyebrow}</p>
      <h2 class="serif" style="font-size:48px; line-height:1.1">{c.stepsHeading}</h2>
    </div>
    <div class="process-grid cols-3">
      {c.steps.map((p, i) => (
        <div class="process-card" style="border-top-color:var(--ink-30)">
          <span class="num" style="color:var(--blue)">{String(i + 1).padStart(2, '0')}</span>
          <div class="title">{p.title}</div>
          <p style="color:var(--ink-85)">{p.copy}</p>
        </div>
      ))}
    </div>
  </section>

  <NextSteps heading={c.next.heading} copy={c.next.copy} />
</Layout>

---
import Layout from '../../layouts/Layout.astro';
import Ticker from '../../components/Ticker.astro';
import Glyph from '../../components/Glyph.astro';
import NextSteps from '../../components/NextSteps.astro';
import { content } from '../../data/content';

const c = content.services;
const coreIcons = [
  `<circle cx="24" cy="24" r="20" stroke="#F6F1E4" stroke-width="1"/><circle cx="24" cy="24" r="12" stroke="#F6F1E4" stroke-width="1"/><circle cx="24" cy="24" r="3" fill="#C7D64F"/>`,
  `<circle cx="18" cy="24" r="13" stroke="#3E4227" stroke-width="1"/><circle cx="30" cy="24" r="13" stroke="#3E4227" stroke-width="1"/><circle cx="24" cy="24" r="3" fill="#3B63C4"/>`,
];
---

<Layout
  title={c.metaTitle}
  description={c.metaDescription}
  active="/services/"
  path="/services/"
>
  <!-- Hero -->
  <section class="hero">
    <div class="col">
      <p class="eyebrow">{c.hero.eyebrow}</p>
      <h1 set:html={c.hero.heading}></h1>
      <p>{c.hero.lead}</p>
      <a class="cta" href="/contact/">Schedule a free consultation <span class="arw">→</span></a>
    </div>
    <Glyph name="concentric" class="hero-figure" />
  </section>

  <Ticker items={c.ticker} label="Who I serve" />

  <!-- Core services -->
  <section class="section">
    <div class="stack gap-20" style="margin-bottom:48px">
      <p class="eyebrow">{c.coreEyebrow}</p>
      <h2 class="serif" style="font-size:48px; line-height:1.1">{c.coreHeading}</h2>
    </div>
    <div class="card-row">
      {
        c.core.map((s, i) => (
          <a class={`big-card ${i === 0 ? 'primary' : 'secondary'}`} href={s.href}>
            <svg viewBox="0 0 48 48" width="44" height="44" fill="none" aria-hidden="true" set:html={coreIcons[i]} />
            <span class="title">{s.title}</span>
            <span class="desc">{s.desc}</span>
            <span class="more">Explore <span class="arw">→</span></span>
          </a>
        ))
      }
    </div>
  </section>

  <!-- Specialties -->
  <section class="section sage on-color">
    <div class="stack gap-20" style="margin-bottom:48px">
      <p class="eyebrow on-color">{c.specialtiesEyebrow}</p>
      <h2 class="serif" style="font-size:48px; line-height:1.1">{c.specialtiesHeading}</h2>
    </div>
    <div class="link-grid cols-3">
      {
        c.specialties.map((s, i) => (
          <a class="link-cell" href={s.href}>
            <span class="num">{String(i + 1).padStart(2, '0')}</span>
            <span class="title">{s.title}</span>
            <span class="desc">{s.desc}</span>
            <span class="more">Learn more <span class="arw">→</span></span>
          </a>
        ))
      }
    </div>
  </section>

  <NextSteps heading={c.next.heading} copy={c.next.copy} />
</Layout>

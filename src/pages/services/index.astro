---
import Layout from '../../layouts/Layout.astro';
import Ticker from '../../components/Ticker.astro';
import Illustration from '../../components/Illustration.astro';
import Faq from '../../components/Faq.astro';
import NextSteps from '../../components/NextSteps.astro';
import { faqPage } from '../../data/schema';

const tickerItems = ['Individuals', 'Couples', 'Teens', 'Creatives', 'Premarital', 'In-Person', 'Online CA'];

const specialties = [
  { href: '/services/premarital-counseling/', title: 'Premarital counseling', desc: 'Explore your attachment histories and expectations before beginning a lifelong commitment.' },
  { href: '/services/therapy-for-anxiety/', title: 'Therapy for anxiety', desc: 'Get to know what your anxiety is responding to and protecting by listening to what it’s trying to tell you.' },
  { href: '/services/therapy-for-creatives/', title: 'Therapy for creatives', desc: 'Navigate burnout, dry spells, and lost direction by understanding the emotional undercurrents beneath them.' },
];

const faqs = [
  { q: 'How do I know if individual or couples therapy is the right place to start?', a: ['If what’s on your mind is mostly about you, your patterns, your history, your inner world, individual therapy is usually the better starting point. If the friction lives mainly between you and a partner, couples therapy lets us work with the relationship directly. Some people do both, at different times or even in the same season. If you’re not sure, the free consultation is a good place to talk it through.'] },
  { q: 'Do you accept insurance?', a: ['I’m currently a private-pay practice. Many of my clients use out-of-network benefits through their PPO plans, and I provide a monthly superbill you can submit for reimbursement; many receive 50 to 80 percent back this way. I also accept HSA and FSA cards.'] },
  { q: 'What age groups do you work with?', a: ['I work with adult individuals, couples, and teens. Each has its own rhythm. Teens are seen without a parent present in the room, though I stay in communication with parents in a way that respects the teen’s privacy and developmental stage.'] },
  { q: 'How do I get started?', a: ['Every service begins the same way: a free 15-minute phone consultation, so we can talk about what’s bringing you in and get a sense of whether working together feels right. From there, we’ll find a rhythm and format, in-person in Newport Beach or Fullerton, or telehealth anywhere in California, that fits your life.'] },
];
---

<Layout
  title="Therapy Services | Newport Beach & Fullerton, CA"
  description="Individual, couples & premarital therapy in Newport Beach & Fullerton, CA, plus specialty care for anxiety and creatives. Telehealth statewide."
  active="/services/"
  path="/services/"
  schema={[
    faqPage(faqs, {
      id: 'https://nikolesparks.com/services#faq',
      url: 'https://nikolesparks.com/services',
    }),
  ]}
>
  <!-- Hero -->
  <section class="hero">
    <div class="col">
      <p class="eyebrow">Services — Newport Beach · Fullerton · Online CA</p>
      <h1>How we can <em>work together.</em></h1>
      <p>
        Depth-oriented therapy for adults, teens, and couples. Every service starts the same
        way, with a free 15-minute consultation to see if we’re a good fit.
      </p>
      <p>
        Read more <a href="/about/" style="color:var(--blue); border-bottom:1px solid var(--blue)">about Nikole</a>
        or learn about <a href="/approach/" style="color:var(--blue); border-bottom:1px solid var(--blue)">my approach</a>.
      </p>
      <a class="cta" href="/contact/">Schedule a free consultation <span class="arw">→</span></a>
    </div>
    <Illustration name="integration-full" size="clamp(380px, 44vw, 520px)" color="var(--blue)" class="hero-figure" />
  </section>

  <Ticker items={tickerItems} label="Who I serve" />

  <!-- Core services -->
  <section class="section">
    <div class="stack gap-20" style="margin-bottom:48px">
      <p class="eyebrow">Core services</p>
      <h2 class="h2-serif">Ways we can work together</h2>
    </div>
    <div class="card-row">
      <a class="big-card primary" href="/services/individual-therapy/">
        <svg viewBox="0 0 48 48" width="44" height="44" fill="none" aria-hidden="true"><circle cx="24" cy="24" r="20" stroke="#F6F1E4" stroke-width="1"/><circle cx="24" cy="24" r="12" stroke="#F6F1E4" stroke-width="1"/><circle cx="24" cy="24" r="3" fill="#C7D64F"/></svg>
        <span class="title">Individual therapy</span>
        <span class="desc">Reimagine your relationship with yourself. Weekly, open-ended depth work on anxiety, identity, shame, grief, and the patterns underneath them.</span>
        <span class="more">Explore <span class="arw">→</span></span>
      </a>
      <a class="big-card secondary" href="/services/couples-therapy/">
        <svg viewBox="0 0 48 48" width="44" height="44" fill="none" aria-hidden="true"><circle cx="18" cy="24" r="13" stroke="#3E4227" stroke-width="1"/><circle cx="30" cy="24" r="13" stroke="#3E4227" stroke-width="1"/><circle cx="24" cy="24" r="3" fill="#3B63C4"/></svg>
        <span class="title">Couples therapy</span>
        <span class="desc">Reconnect, rebuild, and rediscover your relationship. Attachment-based therapy to build more satisfying ways to connect, and strengthen your foundation.</span>
        <span class="more">Explore <span class="arw">→</span></span>
      </a>
    </div>
  </section>

  <!-- Specialties -->
  <section class="section sage on-color">
    <div class="stack gap-20" style="margin-bottom:48px">
      <p class="eyebrow on-color">Specialties</p>
      <h2 class="h2-serif">Focused areas of care</h2>
    </div>
    <div class="link-grid cols-3">
      {
        specialties.map((s, i) => (
          <a class="link-cell" href={s.href}>
            <span class="num">{String(i + 1).padStart(2, '0')}</span>
            <span class="title">{s.title}</span>
            <span class="desc">{s.desc}</span>
            <span class="more">Learn more <span class="arw">→</span></span>
          </a>
        ))
      }
    </div>
  </section>

  <!-- FAQs -->
  <section class="section" style="display:grid; grid-template-columns:1fr 1.5fr; gap:80px; align-items:start">
    <div class="sticky-heading">
      <p class="eyebrow">Services</p>
      <h2 class="h2-serif">Frequently asked questions</h2>
      <Illustration name="questions-full" size="240px" class="mt-16" />
    </div>
    <Faq items={faqs} />
  </section>

  <NextSteps
    heading="Not sure where to start? <em>Let’s figure it out together.</em>"
    copy="The free 15-minute consultation is the easiest way to find the right starting point. No pressure, no commitment, just a conversation."
  />
</Layout>

<style>
  @media (max-width: 820px) {
    section[style*='grid-template-columns:1fr 1.5fr'] {
      grid-template-columns: 1fr !important;
      gap: 40px !important;
    }
  }
</style>

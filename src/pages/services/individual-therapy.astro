---
import Layout from '../../layouts/Layout.astro';
import Ticker from '../../components/Ticker.astro';
import Glyph from '../../components/Glyph.astro';
import Faq from '../../components/Faq.astro';
import NextSteps from '../../components/NextSteps.astro';
import { content } from '../../data/content';

const c = content.individual;
const processIcons = [
  `<circle cx="24" cy="24" r="18" stroke="#C7D64F" stroke-width="1"/><circle cx="24" cy="24" r="4" fill="#C7D64F"/>`,
  `<circle cx="24" cy="24" r="18" stroke="#C7D64F" stroke-width="1"/><circle cx="24" cy="24" r="11" stroke="#C7D64F" stroke-width="1"/><circle cx="24" cy="24" r="4" fill="#C7D64F"/>`,
  `<circle cx="18" cy="24" r="13" stroke="#C7D64F" stroke-width="1"/><circle cx="30" cy="24" r="13" stroke="#C7D64F" stroke-width="1"/>`,
];
---

<Layout title={c.metaTitle} description={c.metaDescription} active="/services/" path="/services/individual-therapy/">
  <!-- Hero -->
  <section class="hero">
    <div class="col">
      <p class="eyebrow"><a href="/services/">Services</a> / {c.hero.crumb}</p>
      <h1 set:html={c.hero.heading}></h1>
      <p set:html={c.hero.lead}></p>
      <a class="cta" href="/contact/">Schedule a free consultation <span class="arw">→</span></a>
    </div>
    <Glyph name="concentric" class="hero-figure" />
  </section>

  <Ticker items={c.ticker} label="What we work on" />

  <!-- Approach -->
  <section class="section blue on-color split c-narrow-wide" style="align-items:center; grid-template-columns:1fr 380px">
    <div class="col gap-28">
      <p class="eyebrow on-color">{c.approach.eyebrow}</p>
      <h2 class="h2-serif" style="font-size:52px" set:html={c.approach.heading}></h2>
      <p class="body">{c.approach.body}</p>
      <a class="text-link on-color" href="/approach/">My approach <span class="arw">→</span></a>
    </div>
    <Glyph name="nested-ellipses" class="hero-figure" />
  </section>

  <!-- Who I work with -->
  <section class="section">
    <div class="stack gap-20" style="margin-bottom:48px">
      <p class="eyebrow">{c.whoEyebrow}</p>
      <h2 class="serif" style="font-size:48px; line-height:1.1; max-width:720px; text-wrap:pretty">{c.whoHeading}</h2>
    </div>
    <div class="ruled-grid cols-2">
      {c.who.map((item, i) => (
        <div class="ruled-cell">
          <span class="num">{String(i + 1).padStart(2, '0')}</span>
          <span class="copy">{item}</span>
        </div>
      ))}
    </div>
  </section>

  <!-- Process -->
  <section class="section sage on-color">
    <div class="stack gap-20" style="margin-bottom:48px">
      <p class="eyebrow on-color">{c.processEyebrow}</p>
      <h2 class="serif" style="font-size:48px; line-height:1.1">{c.processHeading}</h2>
    </div>
    <div class="process-grid cols-3">
      {c.process.map((p, i) => (
        <div class="process-card">
          <div class="head">
            <span class="num">{String(i + 1).padStart(2, '0')}</span>
            <svg viewBox="0 0 48 48" width="34" height="34" fill="none" aria-hidden="true" set:html={processIcons[i]} />
          </div>
          <div class="title">{p.title}</div>
          <p>{p.copy}</p>
        </div>
      ))}
    </div>
  </section>

  <!-- FAQs -->
  <section class="section" style="display:grid; grid-template-columns:1fr 1.5fr; gap:80px; align-items:start">
    <div class="sticky-heading">
      <p class="eyebrow">{c.faqEyebrow}</p>
      <h2 class="h2-serif">Frequently asked questions</h2>
      <Glyph name="target-ellipses" class="mt-16" />
    </div>
    <Faq items={c.faqs} />
  </section>

  <NextSteps heading={c.next.heading} copy={c.next.copy} />
</Layout>

<style>
  @media (max-width: 820px) {
    section[style*='grid-template-columns:1fr 1.5fr'] {
      grid-template-columns: 1fr !important;
      gap: 40px !important;
    }
  }
</style>

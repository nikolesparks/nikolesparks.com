---
import Layout from '../../layouts/Layout.astro';
import Glyph from '../../components/Glyph.astro';
import Illustration from '../../components/Illustration.astro';
import Faq from '../../components/Faq.astro';
import NextSteps from '../../components/NextSteps.astro';
import { individualTherapyService, faqPage } from '../../data/schema';

const whoIWorkWith = [
  'High-functioning people managing daily responsibilities while battling persistent emptiness, heaviness, or feeling underwater',
  'Outwardly successful individuals exhausted by the fear of being “found out” as not good enough',
  'People whose difficult past experiences keep showing up uninvited in their present relationships and sense of self',
  'Those caught in cycles of persistent worry, low mood, self-criticism, or unresolved grief',
  'Creatives facing inspiration dry spells, burnout, or uncertainty about their professional direction',
  'Parents who want to do better but are drowning in self-doubt and harsh self-criticism',
  'People questioning their identity and struggling to show up authentically in their life roles',
  'Individuals seeking a safe space to explore questions around intimacy and sexuality they can’t discuss elsewhere',
  'Those who feel disconnected from partners or family, as if speaking entirely different languages',
  'People who’ve thought “maybe I should talk to someone” repeatedly — and are finally curious',
];

const process = [
  { title: 'Getting started', copy: 'Our first few meetings are about getting comfortable with each other. I’ll listen closely to what brings you in, and together we’ll figure out what you’re hoping to gain.', icon: `<circle cx="24" cy="24" r="18" stroke="#C7D64F" stroke-width="1"/><circle cx="24" cy="24" r="4" fill="#C7D64F"/>` },
  { title: 'Ongoing work', copy: 'We’ll typically meet weekly, creating a consistent rhythm that helps us dive deeper. We move at whatever pace feels right for you, honoring your readiness to explore.', icon: `<circle cx="24" cy="24" r="18" stroke="#C7D64F" stroke-width="1"/><circle cx="24" cy="24" r="11" stroke="#C7D64F" stroke-width="1"/><circle cx="24" cy="24" r="4" fill="#C7D64F"/>` },
  { title: 'Growing together', copy: 'The relationship we build becomes one of the most powerful parts of therapy — the way we connect in sessions offers new insight into how you relate to others in your life.', icon: `<circle cx="18" cy="24" r="13" stroke="#C7D64F" stroke-width="1"/><circle cx="30" cy="24" r="13" stroke="#C7D64F" stroke-width="1"/>` },
];

const faqs = [
  { q: 'What does individual therapy actually look like in your practice?', a: ['Individual therapy with me is weekly and open-ended. Sessions are 45–50 minutes. There’s no worksheet, no structured agenda. You talk about what’s on your mind, and I listen carefully for the emotional threads, patterns, and meanings beneath the surface. My style is warm and engaged — I bring curiosity, care, and at times my perspective into the room. Progress tends to show up gradually: in how you relate to yourself and others, in what you can tolerate, in what you’re able to feel and say freely.'] },
  { q: 'What’s the difference between anxiety therapy and depth therapy?', a: ['Anxiety therapy describes a range of approaches; depth therapy is specifically concerned with understanding what the anxiety is responding to, not just managing it. For a full breakdown of how this works in practice, see the <a href="/services/therapy-for-anxiety/">Therapy for Anxiety</a> page.'] },
  { q: 'Do you work with people experiencing depression?', a: ['Yes — including the forms of depression that are easy to miss from the outside: the kind that coexists with high functioning and an apparently intact life. People often come to me not because they can’t get out of bed, but because life feels hollow, flat, or somehow not their own. Depth-oriented therapy looks at the history and meaning of the depression, not only its symptoms — what has become muted, cut off, or turned inward, and how those patterns can shift through witnessing and understanding.'] },
  { q: 'Can therapy help with shame?', a: ['Yes, and this is some of the most important work I do. Shame is self-concealing — it makes disclosure feel dangerous, so it often goes unnamed in therapy. I move toward shame with care and curiosity, not confrontation. We look at where it came from, what it’s protecting, and how it operates in your relationships and inner life. That kind of shame has often been carried alone for a long time; understanding it can be one of the most freeing things therapy makes possible.'] },
  { q: 'What if I don’t know what to talk about?', a: ['That’s more common than you’d think, and it’s not a problem at all. Sometimes not knowing what to talk about is itself worth exploring. I’m a partner with you — over time, the space starts to feel more natural, and having room for things to surface that you didn’t expect is often where the most meaningful work happens.'] },
  { q: 'Do you offer therapy for teens?', a: ['Yes. I work with teens and adolescents as well as adults — there’s often an opportunity to address patterns earlier, before they become more entrenched. I tailor my approach to be accessible for younger clients. Parents are generally not present in sessions, though we’ll discuss how communication is handled based on the teen’s age and circumstances.'] },
];
---

<Layout
  title="Individual Therapy | Newport Beach & Fullerton, CA"
  description="Depth-oriented individual therapy in Newport Beach & Fullerton, CA (telehealth statewide). Work through anxiety, identity & relationship patterns."
  active="/services/"
  path="/services/individual-therapy/"
  schema={[
    individualTherapyService,
    faqPage(faqs, {
      id: 'https://nikolesparks.com/services/individual-therapy#faq',
      url: 'https://nikolesparks.com/services/individual-therapy',
    }),
  ]}
>
  <!-- Hero (blue) -->
  <section class="hero blue on-color">
    <div class="col">
      <p class="eyebrow on-color"><a href="/services/">Services</a> / Individual therapy</p>
      <h1>Reimagine your relationship <em>with yourself.</em></h1>
      <p>
        Individual therapy in Newport Beach, Fullerton &amp; online throughout California.
        Weekly, open-ended depth work — no worksheets, no scripts, just careful attention to
        what’s underneath.
      </p>
      <a class="cta on-blue" href="/contact/">Schedule a free consultation <span class="arw">→</span></a>
    </div>
    <svg class="hero-figure" viewBox="0 0 480 460" fill="none" aria-hidden="true">
      <ellipse cx="240" cy="230" rx="190" ry="70" stroke="#F6F1E4" stroke-width="2" transform="rotate(-30 240 230)"></ellipse>
      <ellipse cx="240" cy="230" rx="190" ry="70" stroke="#F6F1E4" stroke-width="2" transform="rotate(30 240 230)"></ellipse>
      <ellipse cx="240" cy="230" rx="190" ry="70" stroke="#F6F1E4" stroke-width="2" transform="rotate(90 240 230)"></ellipse>
      <circle cx="240" cy="230" r="6" fill="#F6F1E4"></circle>
      <circle cx="240" cy="40" r="7" fill="#C7D64F"></circle>
    </svg>
  </section>

  <!-- Approach (cream) -->
  <section class="section split c-narrow-wide" style="align-items:center; grid-template-columns:1fr 380px">
    <div class="col gap-28">
      <p class="eyebrow">The approach</p>
      <h2 class="h2-serif" style="font-size:52px">Psychodynamic &amp; <em>attachment-based.</em></h2>
      <p class="body">Understanding our past helps illuminate our present. We’ll gently explore how your early relationships have influenced who you are today, uncover patterns that might be holding you back, understand the “why” behind your feelings, and work to transform your relationships in ways that feel more fulfilling.</p>
      <p class="body">Working with a partner instead? Learn about <a href="/services/couples-therapy/" style="color:var(--blue); border-bottom:1px solid var(--blue)">couples therapy</a>, or read more <a href="/about/" style="color:var(--blue); border-bottom:1px solid var(--blue)">about Nikole</a>.</p>
      <a class="text-link" href="/approach/">My approach <span class="arw">→</span></a>
    </div>
    <Glyph name="concentric" class="hero-figure" />
  </section>

  <!-- Who I work with -->
  <section class="section">
    <div class="stack gap-20" style="margin-bottom:48px">
      <p class="eyebrow">Who I work with</p>
      <h2 class="serif" style="font-size:48px; line-height:1.1; max-width:720px; text-wrap:pretty">
        Capable on the outside. Carrying something underneath.
      </h2>
    </div>
    <div class="ruled-grid cols-2">
      {whoIWorkWith.map((item, i) => (
        <div class="ruled-cell">
          <span class="num">{String(i + 1).padStart(2, '0')}</span>
          <span class="copy">{item}</span>
        </div>
      ))}
    </div>
  </section>

  <!-- Process -->
  <section class="section sage on-color">
    <div class="stack gap-20" style="margin-bottom:48px">
      <p class="eyebrow on-color">The process</p>
      <h2 class="serif" style="font-size:48px; line-height:1.1">How the work unfolds</h2>
    </div>
    <div class="process-grid cols-3">
      {process.map((p, i) => (
        <div class="process-card">
          <div class="head">
            <span class="num">{String(i + 1).padStart(2, '0')}</span>
            <svg viewBox="0 0 48 48" width="34" height="34" fill="none" aria-hidden="true" set:html={p.icon} />
          </div>
          <div class="title">{p.title}</div>
          <p>{p.copy}</p>
        </div>
      ))}
    </div>
  </section>

  <!-- FAQs -->
  <section class="section" style="display:grid; grid-template-columns:1fr 1.5fr; gap:80px; align-items:start">
    <div class="sticky-heading">
      <p class="eyebrow">Individual therapy</p>
      <h2 class="h2-serif">Frequently asked questions</h2>
      <Illustration name="questions-full" size="240px" class="mt-16" />
    </div>
    <Faq items={faqs} />
  </section>

  <NextSteps
    heading="Ready to begin? <em>Let’s talk.</em>"
    copy="I offer a free 15-minute consultation — a chance to ask questions and get a feel for how we might work together. In-person in Newport Beach and Fullerton, or online throughout California."
  />
</Layout>

<style>
  @media (max-width: 820px) {
    section[style*='grid-template-columns:1fr 1.5fr'] {
      grid-template-columns: 1fr !important;
      gap: 40px !important;
    }
  }
</style>

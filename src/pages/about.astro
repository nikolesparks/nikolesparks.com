---
import Layout from '../layouts/Layout.astro';
import Ticker from '../components/Ticker.astro';
import Portrait from '../components/Portrait.astro';
import Glyph from '../components/Glyph.astro';
import NextSteps from '../components/NextSteps.astro';
import { site } from '../data/site';
import { content } from '../data/content';

const c = content.about;

// Education icons stay in the page; text comes from content.
const eduIcons = [
  `<circle cx="24" cy="24" r="20" stroke="#3B63C4" stroke-width="1"/><circle cx="24" cy="24" r="12" stroke="#3B63C4" stroke-width="1"/><circle cx="24" cy="24" r="3" fill="#3B63C4"/>`,
  `<ellipse cx="24" cy="28" rx="19" ry="6" stroke="#3B63C4" stroke-width="1"/><ellipse cx="24" cy="23" rx="19" ry="12" stroke="#3B63C4" stroke-width="1"/><circle cx="24" cy="9" r="3" fill="#C7D64F"/>`,
  `<circle cx="18" cy="24" r="13" stroke="#3B63C4" stroke-width="1"/><circle cx="30" cy="24" r="13" stroke="#3B63C4" stroke-width="1"/>`,
];
---

<Layout title={c.metaTitle} active="/about/" path="/about/">
  <!-- Hero -->
  <section class="hero">
    <div class="col">
      <p class="eyebrow">{c.hero.eyebrow}</p>
      <h1 set:html={c.hero.heading}></h1>
      <p>{c.hero.lead}</p>
      <a class="cta" href="/contact/">Schedule a free consultation <span class="arw">→</span></a>
    </div>
    <Portrait
      placeholder="Nikole — portrait"
      tall
      accent="tr"
      caption={`CA AMFT 150080 · ${site.supervisor}`}
    />
  </section>

  <Ticker items={c.ticker} label="How I work" />

  <!-- Story -->
  <section class="section split c-narrow-wide">
    <div class="col gap-20">
      <p class="eyebrow">{c.story.eyebrow}</p>
      <h2 class="h2-serif" set:html={c.story.heading}></h2>
      <Glyph name="target-ellipses" class="mt-16" />
    </div>
    <div class="prose" style="gap:24px">
      {c.story.paras.map((p) => <p>{p}</p>)}
    </div>
  </section>

  <!-- Education -->
  <section class="section" style="padding-top:0">
    <p class="eyebrow" style="margin-bottom:40px">{c.educationEyebrow}</p>
    <div class="ruled-grid cols-3 feature">
      {
        c.education.map((e, i) => (
          <div class="ruled-cell">
            <svg viewBox="0 0 48 48" width="36" height="36" fill="none" aria-hidden="true" set:html={eduIcons[i]} />
            <span style="font-size:17px; line-height:1.5">
              <span set:html={e.degree} /><br />
              <span class="label" style="color:var(--ink-65); text-transform:none">{e.school}</span>
            </span>
          </div>
        ))
      }
    </div>
  </section>

  <!-- Quote -->
  <section class="quote-block">
    <Glyph name="rings" class="hero-figure" />
    <div class="col gap-28">
      <blockquote set:html={c.quote.text}></blockquote>
      <cite>{c.quote.cite}</cite>
    </div>
  </section>

  <!-- You might be here because -->
  <section class="section">
    <div class="section-heading">
      <div class="stack">
        <p class="eyebrow">{c.hereBecause.eyebrow}</p>
        <h2 class="serif" style="font-size:48px; line-height:1.1; max-width:720px; text-wrap:pretty" set:html={c.hereBecause.heading}></h2>
      </div>
    </div>
    <div class="ruled-grid cols-2">
      {
        c.hereBecause.items.map((item, i) => (
          <div class="ruled-cell">
            <span class="num">{String(i + 1).padStart(2, '0')}</span>
            <span class="copy">{item}</span>
          </div>
        ))
      }
    </div>
    <div class="card-row" style="margin-top:48px">
      <a class="service-card primary" href="/services/individual-therapy/"><span>Individual therapy</span><span class="arw" aria-hidden="true">→</span></a>
      <a class="service-card secondary" href="/services/couples-therapy/"><span>Couples therapy</span><span class="arw" aria-hidden="true">→</span></a>
    </div>
  </section>

  <!-- Helpful to know -->
  <section class="section sage on-color relative overflow-clip">
    <Glyph name="radiate" class="decor" />
    <div class="stack gap-20" style="margin-bottom:56px; position:relative">
      <p class="eyebrow on-color">{c.helpful.eyebrow}</p>
      <h2 class="serif" style="font-size:48px; line-height:1.1">{c.helpful.heading}</h2>
    </div>
    <div class="detail-cards">
      {
        c.helpful.details.map((d) => (
          <div class="detail-card">
            <div class="label">{d.label}</div>
            <div class="big" set:html={d.big} />
            <p>{d.copy}</p>
          </div>
        ))
      }
    </div>
  </section>

  <NextSteps heading={c.next.heading} copy={c.next.copy} steps={c.next.steps} />
</Layout>

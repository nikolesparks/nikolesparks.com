---
interface Props {
  items: string[];
  label?: string;
  variant?: 'ink' | 'blue';
}
const { items, label = 'Areas of focus', variant = 'ink' } = Astro.props;
---

<div class={`ticker${variant === 'blue' ? ' blue' : ''}`} aria-label={label}>
  {
    items.map((item, i) => (
      <>
        <span>{item}</span>
        {i < items.length - 1 && <span aria-hidden="true">·</span>}
      </>
    ))
  }
</div>
